task opensearch_upgrade "Upgrade OpenSearch to 3.x.y" {

  task k8s "Upgrade OpenSearch on k8s" {
    task preparation "Prepare and validate upgrade" {
      duration 4w
    }
    task ipoid "IPoid" {
      duration 1w
      depends !preparation
    }
    task semantic_search "Semantic Search" {
      duration 1w
      depends !preparation
    }
  }

  task baremetal "Upgrade OpenSearch baremetal (CirrusSearch)" {
    duration 3w
    depends !k8s.preparation
    start 2026-05-15
  }
}